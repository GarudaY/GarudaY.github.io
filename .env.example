# Public canonical URL used for metadata, sitemap and structured data.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional absolute directory for the local JSON operations store.
# Leave unset to use .data/ inside the project.
# LOCAL_DATA_DIR=C:\path\to\persistent-data

# Cancelled registrations and resolved contacts are removed after this period.
LOCAL_DATA_RETENTION_DAYS=30
